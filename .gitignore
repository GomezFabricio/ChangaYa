# Build outputs
build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages

# Generated files
*.g.dart
*.freezed.dart
*.mocks.dart

# Coverage
coverage/

# Pub cache (always use pubspec.lock, not the cache)
.pub-cache/
.pub/

# iOS
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Runner/GeneratedPluginRegistrant.*
ios/Runner/GoogleService-Info.plist

# Android
